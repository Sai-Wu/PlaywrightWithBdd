# Playwright Test Configuration
# Copy this file to .env and fill in with actual values
# .env file is git-ignored for security

# Base URL for tests
TEST_BASE_URL=https://www.amazon.com/

# Shared account credentials (for tests that must run sequentially)
SHARED_ACCOUNT_USERNAME=shared.test.account@amazon.com
SHARED_ACCOUNT_PASSWORD=your_shared_account_password_here

# Parallel account credentials (for tests that can run concurrently)
PARALLEL_ACCOUNT_USERNAME=parallel.test.account@amazon.com
PARALLEL_ACCOUNT_PASSWORD=your_parallel_account_password_here

# Playwright Configuration
PLAYWRIGHT_BROWSERS=chromium
PLAYWRIGHT_HEADLESS=true

# Optional: Enable debug mode for more verbose logging
# DEBUG=pw:api
