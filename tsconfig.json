{
    "compilerOptions": {
        "target": "es2021",
        "module": "commonjs",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "types": ["node"],
        "lib": ["ES2021","DOM","DOM.Iterable"]
    },
    "include": [
        "src/typescript/step-definitions/*.ts"
    ],
    "ts-node": {
        "transpileOnly": true,
        "files": true
    }
}